#!/bin/bash

SERVICE_NAME="visitor"
INSTALL_DIR="/opt/visitor"
CONFIG_FILE="$INSTALL_DIR/config.yaml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

usage() {
    echo "Visitor CLI - Manage Visitor Tracker Service"
    echo ""
    echo "Usage: visitor <command> [options]"
    echo ""
    echo "Commands:"
    echo "  start              Start the service"
    echo "  stop               Stop the service"
    echo "  restart            Restart the service"
    echo "  status             Show service status"
    echo "  port <number>      Change port"
    echo "  password <pwd>      Change admin password"
    echo "  log                Show service logs (follow mode)"
    echo "  config             Show current config"
    echo ""
    echo "Examples:"
    echo "  visitor start"
    echo "  visitor port 9000"
    echo "  visitor password mysecret"
    exit 1
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}Please run as root: sudo visitor $1${NC}"
        exit 1
    fi
}

cmd_start() {
    systemctl start "$SERVICE_NAME"
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}Service started successfully${NC}"
    else
        echo -e "${RED}Failed to start service${NC}"
        exit 1
    fi
}

cmd_stop() {
    systemctl stop "$SERVICE_NAME"
    echo -e "${GREEN}Service stopped${NC}"
}

cmd_restart() {
    systemctl restart "$SERVICE_NAME"
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}Service restarted successfully${NC}"
    else
        echo -e "${RED}Failed to restart service${NC}"
        exit 1
    fi
}

cmd_status() {
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}● $SERVICE_NAME is running${NC}"
    else
        echo -e "${RED}● $SERVICE_NAME is stopped${NC}"
    fi
    systemctl status "$SERVICE_NAME" --no-pager
}

cmd_port() {
    check_root "port $1"
    local new_port="$1"
    
    if [ -z "$new_port" ]; then
        echo -e "${RED}Error: Port number required${NC}"
        echo "Usage: visitor port <number>"
        exit 1
    fi
    
    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Config file not found at $CONFIG_FILE${NC}"
        exit 1
    fi
    
    sed -i "s/port:.*/port: $new_port/" "$CONFIG_FILE"
    echo -e "${GREEN}Port changed to $new_port${NC}"
    
    cmd_restart
}

cmd_password() {
    check_root "password <hidden>"
    local new_password="$1"
    
    if [ -z "$new_password" ]; then
        echo -e "${RED}Error: Password required${NC}"
        echo "Usage: visitor password <password>"
        exit 1
    fi
    
    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Config file not found at $CONFIG_FILE${NC}"
        exit 1
    fi
    
    sed -i "s/admin_password:.*/admin_password: \"$new_password\"/" "$CONFIG_FILE"
    echo -e "${GREEN}Password changed successfully${NC}"
}

cmd_log() {
    journalctl -u "$SERVICE_NAME" -f
}

cmd_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Config file not found at $CONFIG_FILE${NC}"
        exit 1
    fi
    cat "$CONFIG_FILE"
}

# Main
if [ $# -eq 0 ]; then
    usage
fi

case "$1" in
    start)
        check_root
        cmd_start
        ;;
    stop)
        check_root
        cmd_stop
        ;;
    restart)
        check_root
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    port)
        cmd_port "$2"
        ;;
    password)
        cmd_password "$2"
        ;;
    log)
        cmd_log
        ;;
    config)
        cmd_config
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        usage
        ;;
esac
