#!/bin/bash

SERVICE_NAME="visitor"
INSTALL_DIR="/opt/visitor"
CONFIG_FILE="$INSTALL_DIR/config.yaml"
CLI_FILE="/usr/local/bin/vtor"
VERSION_FILE="$INSTALL_DIR/version"
REPO="tocha688/go-visitor-web"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

usage() {
    echo "vtor - Visitor Tracker CLI v1.0.0"
    echo ""
    echo "Usage: vtor <command> [options]"
    echo ""
    echo "Commands:"
    echo "  start              Start the service"
    echo "  stop               Stop the service"
    echo "  restart            Restart the service"
    echo "  status             Show service status"
    echo "  version            Show current version"
    echo "  port <num>         Change port"
    echo "  password <pwd>     Change admin password"
    echo "  log                Show service logs (follow mode)"
    echo "  config             Show current config"
    echo "  upgrade            Upgrade to latest version"
    echo "  uninstall          Uninstall service and files"
    echo ""
    echo "Examples:"
    echo "  vtor start"
    echo "  vtor port 9000"
    echo "  vtor password mysecret"
    echo "  vtor upgrade"
    echo "  vtor uninstall"
    exit 1
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        echo -e "${RED}Please run as root: sudo vtor $1${NC}"
        exit 1
    fi
}

get_latest_version() {
    LATEST_VERSION=$(curl -s https://api.github.com/repos/$REPO/releases/latest | grep -oP '"tag_name":\s*"\K[^"]+' | sed 's/v//')
    echo "$LATEST_VERSION"
}

get_local_version() {
    if [ -f "$VERSION_FILE" ]; then
        cat "$VERSION_FILE"
    else
        echo "0.0.0"
    fi
}

compare_versions() {
    local v1="$1"
    local v2="$2"
    
    if [ "$v1" = "$v2" ]; then
        echo "equal"
        return 0
    fi
    
    local v1_major=$(echo "$v1" | cut -d. -f1)
    local v1_minor=$(echo "$v1" | cut -d. -f2)
    local v1_patch=$(echo "$v1" | cut -d. -f3)
    local v2_major=$(echo "$v2" | cut -d. -f1)
    local v2_minor=$(echo "$v2" | cut -d. -f2)
    local v2_patch=$(echo "$v2" | cut -d. -f3)
    
    if [ "$v1_major" -lt "$v2_major" ]; then
        echo "lower"
        return 0
    elif [ "$v1_major" -gt "$v2_major" ]; then
        echo "higher"
        return 0
    fi
    
    if [ "$v1_minor" -lt "$v2_minor" ]; then
        echo "lower"
        return 0
    elif [ "$v1_minor" -gt "$v2_minor" ]; then
        echo "higher"
        return 0
    fi
    
    if [ "$v1_patch" -lt "$v2_patch" ]; then
        echo "lower"
        return 0
    else
        echo "higher"
        return 0
    fi
}

cmd_start() {
    systemctl start "$SERVICE_NAME"
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}Service started successfully${NC}"
    else
        echo -e "${RED}Failed to start service${NC}"
        exit 1
    fi
}

cmd_stop() {
    systemctl stop "$SERVICE_NAME"
    echo -e "${GREEN}Service stopped${NC}"
}

cmd_restart() {
    systemctl restart "$SERVICE_NAME"
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}Service restarted successfully${NC}"
    else
        echo -e "${RED}Failed to restart service${NC}"
        exit 1
    fi
}

cmd_status() {
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}● $SERVICE_NAME is running${NC}"
    else
        echo -e "${RED}● $SERVICE_NAME is stopped${NC}"
    fi
    systemctl status "$SERVICE_NAME" --no-pager
}

cmd_version() {
    local local_ver=$(get_local_version)
    echo "Current version: v$local_ver"
    
    echo "Fetching latest version..."
    local latest_ver=$(get_latest_version)
    if [ -z "$latest_ver" ]; then
        echo -e "${RED}Failed to fetch latest version${NC}"
        exit 1
    fi
    echo "Latest version: v$latest_ver"
    
    local cmp=$(compare_versions "$local_ver" "$latest_ver")
    if [ "$cmp" = "lower" ]; then
        echo -e "${YELLOW}A newer version is available${NC}"
    elif [ "$cmp" = "equal" ]; then
        echo -e "${GREEN}You are on the latest version${NC}"
    else
        echo -e "${YELLOW}You are on a newer version (dev build?)${NC}"
    fi
}

cmd_port() {
    check_root "port $1"
    local new_port="$1"
    
    if [ -z "$new_port" ]; then
        echo -e "${RED}Error: Port number required${NC}"
        echo "Usage: vtor port <number>"
        exit 1
    fi
    
    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Config file not found at $CONFIG_FILE${NC}"
        exit 1
    fi
    
    sed -i "s/port:.*/port: $new_port/" "$CONFIG_FILE"
    echo -e "${GREEN}Port changed to $new_port${NC}"
    cmd_restart
}

cmd_password() {
    check_root "password <hidden>"
    local new_password="$1"
    
    if [ -z "$new_password" ]; then
        echo -e "${RED}Error: Password required${NC}"
        echo "Usage: vtor password <password>"
        exit 1
    fi
    
    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Config file not found at $CONFIG_FILE${NC}"
        exit 1
    fi
    
    sed -i "s/admin_password:.*/admin_password: \"$new_password\"/" "$CONFIG_FILE"
    echo -e "${GREEN}Password changed successfully${NC}"
}

cmd_log() {
    journalctl -u "$SERVICE_NAME" -f
}

cmd_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        echo -e "${RED}Config file not found at $CONFIG_FILE${NC}"
        exit 1
    fi
    cat "$CONFIG_FILE"
}

cmd_upgrade() {
    check_root
    
    echo -e "${YELLOW}=== Upgrading Visitor Tracker ===${NC}"
    echo ""
    
    local local_ver=$(get_local_version)
    echo "Current version: v$local_ver"
    
    echo "Fetching latest version..."
    local latest_ver=$(get_latest_version)
    if [ -z "$latest_ver" ]; then
        echo -e "${RED}Failed to fetch latest version${NC}"
        exit 1
    fi
    echo "Latest version: v$latest_ver"
    
    local cmp=$(compare_versions "$local_ver" "$latest_ver")
    if [ "$cmp" = "equal" ]; then
        echo -e "${GREEN}You are already on the latest version${NC}"
        return 0
    elif [ "$cmp" = "higher" ]; then
        echo -e "${YELLOW}You are on a newer version than latest release (dev build?)${NC}"
        read -p "Continue anyway? [y/N] " -n 1 -r
        echo ""
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            echo "Upgrade cancelled"
            exit 0
        fi
    fi
    
    ARCH=$(uname -m)
    case $ARCH in
        x86_64)
            ARCH_NAME="amd64"
            ;;
        i386|i686)
            ARCH_NAME="386"
            ;;
        aarch64|arm64)
            ARCH_NAME="arm64"
            ;;
        *)
            echo -e "${RED}Unsupported architecture: $ARCH${NC}"
            exit 1
            ;;
    esac
    echo "Architecture: $ARCH_NAME"
    
    FILENAME="visitor-linux-$ARCH_NAME.tar.gz"
    DOWNLOAD_URL="https://github.com/$REPO/releases/download/v$latest_ver/$FILENAME"
    
    echo ""
    echo "Downloading..."
    cd /tmp
    curl -# -L -o "$FILENAME" "$DOWNLOAD_URL"
    
    echo "Extracting..."
    tar -xzf "$FILENAME"
    
    echo "Stopping service..."
    systemctl stop "$SERVICE_NAME"
    
    echo "Upgrading binary..."
    cp "$INSTALL_DIR/visitor" "$INSTALL_DIR/visitor.bak"
    cp "visitor-linux-$ARCH_NAME" "$INSTALL_DIR/visitor"
    chmod +x "$INSTALL_DIR/visitor"
    
    # Save new version
    echo "$latest_ver" > "$VERSION_FILE"
    echo "Version saved: v$latest_ver"
    
    rm -f "visitor-linux-$ARCH_NAME"
    
    echo "Starting service..."
    systemctl start "$SERVICE_NAME"
    
    rm -f /tmp/$FILENAME
    
    echo ""
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        echo -e "${GREEN}=== Upgrade Complete: v$latest_ver ===${NC}"
    else
        echo -e "${RED}Upgrade failed, restoring backup...${NC}"
        cp "$INSTALL_DIR/visitor.bak" "$INSTALL_DIR/visitor"
        systemctl start "$SERVICE_NAME"
        exit 1
    fi
}

cmd_uninstall() {
    check_root
    
    echo -e "${YELLOW}=== Uninstall Visitor Tracker ===${NC}"
    echo ""
    echo "This will:"
    echo "  - Stop and disable the $SERVICE_NAME service"
    echo "  - Remove $SERVICE_FILE"
    echo "  - Remove $CLI_FILE"
    echo "  - Remove $INSTALL_DIR"
    echo ""
    read -p "Are you sure you want to uninstall? [y/N] " -n 1 -r
    echo ""
    
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${RED}Uninstall cancelled${NC}"
        exit 0
    fi
    
    echo "Stopping service..."
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        systemctl stop "$SERVICE_NAME"
    fi
    
    if systemctl is-enabled --quiet "$SERVICE_NAME"; then
        systemctl disable "$SERVICE_NAME"
    fi
    
    if [ -f "$SERVICE_FILE" ]; then
        rm -f "$SERVICE_FILE"
        systemctl daemon-reload
        echo "Service file removed"
    fi
    
    if [ -f "$CLI_FILE" ]; then
        rm -f "$CLI_FILE"
        echo "CLI removed"
    fi
    
    if [ -d "$INSTALL_DIR" ]; then
        rm -rf "$INSTALL_DIR"
        echo "Installation directory removed"
    fi
    
    echo ""
    echo -e "${GREEN}=== Uninstall Complete ===${NC}"
}

# Main
if [ $# -eq 0 ]; then
    usage
fi

case "$1" in
    start)
        check_root
        cmd_start
        ;;
    stop)
        check_root
        cmd_stop
        ;;
    restart)
        check_root
        cmd_restart
        ;;
    status)
        cmd_status
        ;;
    version)
        cmd_version
        ;;
    port)
        cmd_port "$2"
        ;;
    password)
        cmd_password "$2"
        ;;
    log)
        cmd_log
        ;;
    config)
        cmd_config
        ;;
    upgrade)
        cmd_upgrade
        ;;
    uninstall)
        cmd_uninstall
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        usage
        ;;
esac
